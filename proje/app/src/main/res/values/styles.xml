<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="App" />

    <style name="App.Button" />

    <style name="App.Screen">
        <item name="android:background">@color/background</item>
        <item name="android:paddingHorizontal">@dimen/screen_padding</item>
        <item name="android:paddingVertical">@dimen/screen_padding_top</item>
    </style>

    <style name="App.TitleText">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">26sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="App.SubtitleText">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:textSize">13sp</item>
    </style>

    <style name="App.BodyText">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="App.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardBackgroundColor">@color/surface</item>
        <item name="cardCornerRadius">@dimen/radius_lg</item>
        <item name="cardElevation">3dp</item>
        <item name="strokeColor">@color/divider</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="App.WordCard" parent="App.Card">
        <item name="cardCornerRadius">@dimen/radius_md</item>
        <item name="cardElevation">2dp</item>
    </style>

    <style name="App.Button.Primary" parent="Widget.MaterialComponents.Button">
        <item name="android:minHeight">@dimen/button_height</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="backgroundTint">@color/primary</item>
        <item name="cornerRadius">@dimen/radius_lg</item>
    </style>

    <style name="App.Button.Outlined" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:minHeight">58dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="cornerRadius">@dimen/radius_lg</item>
        <item name="iconTint">@color/primary</item>
        <item name="strokeColor">@color/divider</item>
    </style>

    <style name="App.Button.Text" parent="Widget.MaterialComponents.Button.TextButton">
        <item name="android:textAllCaps">false</item>
        <item name="cornerRadius">@dimen/radius_lg</item>
    </style>

    <style name="App.Button.ToolbarIcon" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:layout_width">48dp</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:minWidth">0dp</item>
        <item name="android:minHeight">0dp</item>
        <item name="android:padding">0dp</item>
        <item name="android:insetLeft">0dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetRight">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="backgroundTint">@color/surface_variant</item>
        <item name="cornerRadius">@dimen/radius_md</item>
        <item name="iconPadding">0dp</item>
        <item name="iconTint">@color/primary</item>
        <item name="rippleColor">@color/hero_panel_stroke</item>
        <item name="strokeColor">@color/hero_panel_stroke</item>
        <item name="strokeWidth">1dp</item>
        <item name="elevation">0dp</item>
    </style>

    <style name="App.TextInput" parent="Widget.MaterialComponents.TextInputLayout.OutlinedBox">
        <item name="boxBackgroundColor">@color/surface</item>
        <item name="boxCornerRadiusBottomEnd">@dimen/radius_sm</item>
        <item name="boxCornerRadiusBottomStart">@dimen/radius_sm</item>
        <item name="boxCornerRadiusTopEnd">@dimen/radius_sm</item>
        <item name="boxCornerRadiusTopStart">@dimen/radius_sm</item>
    </style>

    <style name="App.IconButton">
        <item name="android:layout_width">@dimen/icon_button_size</item>
        <item name="android:layout_height">@dimen/icon_button_size</item>
        <item name="android:background">@drawable/modern_icon_button_bg</item>
        <item name="android:padding">@dimen/icon_button_padding</item>
    </style>
</resources>
