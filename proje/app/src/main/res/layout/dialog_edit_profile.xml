<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:fillViewport="false"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="18dp"
        android:paddingTop="12dp"
        android:paddingEnd="18dp"
        android:paddingBottom="8dp">

        <ImageView
            android:id="@+id/imgEditProfile"
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:layout_gravity="center_horizontal"
            android:background="@drawable/profile_avatar_bg"
            android:clipToOutline="true"
            android:clickable="true"
            android:contentDescription="Profil resmi"
            android:focusable="true"
            android:padding="16dp"
            android:scaleType="centerCrop"
            android:src="@drawable/ic_person_circle_24" />

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilEditUsername"
            style="@style/App.TextInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:hint="Kullanıcı adı">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etEditUsername"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPersonName"
                android:maxLines="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilEditFullName"
            style="@style/App.TextInput"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="Gerçek ad">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etEditFullName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPersonName"
                android:maxLines="1" />
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnShowPasswordReset"
            style="@style/App.Button.Outlined"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="16dp"
            android:text="Şifremi Sıfırla"
            android:textColor="@color/text_primary"
            app:icon="@android:drawable/ic_lock_lock"
            app:iconGravity="textStart"
            app:iconTint="@color/accent" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnDialogLogout"
            style="@style/App.Button.Text"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="14dp"
            android:backgroundTint="@color/danger_soft"
            android:text="Çıkış Yap"
            android:textColor="@color/danger"
            android:textStyle="bold"
            app:icon="@android:drawable/ic_lock_power_off"
            app:iconTint="@color/danger"
            app:rippleColor="@color/danger_soft"
            app:strokeColor="@color/danger"
            app:strokeWidth="1dp" />
    </LinearLayout>
</ScrollView>
