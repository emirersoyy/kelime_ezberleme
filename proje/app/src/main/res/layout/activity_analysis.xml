<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical"
    android:paddingHorizontal="@dimen/screen_padding"
    android:paddingVertical="@dimen/screen_padding_top">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/btnBack"
            style="@style/App.IconButton"
            android:src="@drawable/ic_arrow_back_24"
            app:tint="@color/text_secondary" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                style="@style/App.TitleText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Analiz Raporu" />

            <TextView
                style="@style/App.SubtitleText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Kelime durumunu ve seviyeni takip et" />
        </LinearLayout>

        <ImageButton
            android:id="@+id/btnPrint"
            style="@style/App.IconButton"
            android:src="@android:drawable/ic_menu_save"
            app:tint="@color/primary" />
    </LinearLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/reportContent"
        style="@style/App.Card"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="22dp"
        android:layout_weight="1">

        <LinearLayout
            android:id="@+id/llReportContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/surface"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Genel Durum"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tvOverallStats"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:background="@drawable/soft_chip_bg"
                android:padding="14dp"
                android:text="Toplam 0 kelime"
                android:textColor="@color/text_primary"
                android:textSize="17sp"
                android:textStyle="bold" />

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:layout_marginVertical="18dp"
                android:background="@color/divider" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Durum Listesi"
                android:textColor="@color/text_secondary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="10dp"
                android:clipToPadding="false">

                <LinearLayout
                    android:id="@+id/llCategoryStats"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />
            </ScrollView>

        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnResetData"
        style="@style/App.Button.Outlined"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_marginTop="16dp"
        android:text="Verilerimi Sıfırla"
        android:textColor="@color/accent"
        android:textStyle="bold"
        app:icon="@android:drawable/ic_menu_delete"
        app:iconTint="@color/accent" />

</LinearLayout>
