<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:orientation="vertical"
        android:paddingHorizontal="@dimen/screen_padding"
        android:paddingVertical="32dp">

        <TextView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:background="@drawable/login_badge_bg"
            android:gravity="center"
            android:text="K"
            android:textColor="@color/white"
            android:textSize="32sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvWelcome"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:text="@string/welcome"
            android:textColor="@color/text_primary"
            android:textSize="30sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="26dp"
            android:gravity="center"
            android:text="Bugünkü kelime pratiğini sakin ve düzenli ilerlet"
            android:textColor="@color/text_secondary"
            android:textSize="14sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnStartQuiz"
            style="@style/App.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="@dimen/button_height_large"
            android:text="Sınava Başla"
            android:textSize="18sp"
            app:icon="@android:drawable/ic_media_play"
            app:iconGravity="textStart"
            app:iconPadding="12dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:orientation="vertical">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAddWordMenu"
                style="@style/App.Button.Outlined"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginBottom="10dp"
                android:text="Kelime Ekle"
                android:textSize="16sp"
                app:icon="@android:drawable/ic_input_add"
                app:iconGravity="textStart"
                app:iconTint="@color/primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnWordsListMenu"
                style="@style/App.Button.Outlined"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginBottom="10dp"
                android:text="Kelimelerim"
                android:textSize="16sp"
                app:icon="@android:drawable/ic_menu_sort_by_size"
                app:iconGravity="textStart"
                app:iconTint="@color/primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAnalysisMenu"
                style="@style/App.Button.Outlined"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginBottom="10dp"
                android:text="Analiz Raporu"
                android:textSize="16sp"
                app:icon="@android:drawable/ic_menu_report_image"
                app:iconGravity="textStart"
                app:iconTint="@color/accent" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnWordleMenu"
                style="@style/App.Button.Outlined"
                android:layout_width="match_parent"
                android:layout_height="58dp"
                android:layout_marginBottom="10dp"
                android:text="Bulmaca (Wordle)"
                android:textSize="16sp"
                app:icon="@android:drawable/ic_menu_help"
                app:iconGravity="textStart"
                app:iconTint="@color/primary" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnSettingsMenu"
                style="@style/App.Button.Text"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:text="Ayarlar"
                android:textColor="@color/text_secondary"
                android:textSize="16sp"
                app:icon="@android:drawable/ic_menu_preferences"
                app:iconGravity="textStart"
                app:iconTint="@color/text_secondary" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
