<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvWelcome"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="32dp"
        android:text="@string/welcome"
        android:textColor="@color/primary"
        android:textSize="24sp"
        android:textStyle="bold" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnStartQuiz"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginBottom="16dp"
        android:text="Sınava Başla"
        android:textAllCaps="false"
        android:textSize="18sp"
        app:backgroundTint="@color/accent"
        app:cornerRadius="16dp"
        app:icon="@android:drawable/ic_media_play" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAddWordMenu"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginBottom="16dp"
        android:text="Kelime Ekle"
        android:textAllCaps="false"
        android:textSize="18sp"
        app:cornerRadius="16dp"
        app:icon="@android:drawable/ic_input_add" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnWordsListMenu"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginBottom="16dp"
        android:text="Kelimelerim"
        android:textAllCaps="false"
        android:textSize="18sp"
        app:cornerRadius="16dp"
        app:icon="@android:drawable/ic_menu_sort_by_size" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnAnalysisMenu"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_marginBottom="16dp"
        android:text="Analiz Raporu"
        android:textAllCaps="false"
        android:textSize="18sp"
        app:cornerRadius="16dp"
        app:icon="@android:drawable/ic_menu_report_image" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnSettingsMenu"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:text="Ayarlar"
        android:textAllCaps="false"
        android:textSize="18sp"
        app:cornerRadius="16dp"
        app:icon="@android:drawable/ic_menu_preferences" />

</LinearLayout>