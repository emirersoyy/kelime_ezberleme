<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/screen_padding"
            android:paddingVertical="28dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <FrameLayout
                    android:layout_width="56dp"
                    android:layout_height="56dp"
                    android:background="@drawable/login_badge_bg">

                    <ImageView
                        android:id="@+id/ivProfileAvatar"
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:layout_gravity="center"
                        android:contentDescription="Hesap fotoÄŸrafÄ±"
                        android:scaleType="centerCrop"
                        android:src="@android:drawable/ic_menu_myplaces" />
                </FrameLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="14dp"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvGreeting"
                        style="@style/App.TitleText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="GÃ¼naydÄ±n" />

                    <TextView
                        android:id="@+id/tvCurrentUser"
                        style="@style/App.SubtitleText"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="KullanÄ±cÄ± adÄ±" />
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:layout_marginBottom="22dp"
                android:text="Bugünkü kelime pratiğini sakin ve düzenli ilerlet"
                android:textColor="@color/text_secondary"
                android:textSize="14sp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnStartQuiz"
                style="@style/App.Button.Primary"
                android:layout_width="match_parent"
                android:layout_height="@dimen/button_height_large"
                android:text="Sınava Başla"
                android:textSize="18sp"
                app:icon="@android:drawable/ic_media_play"
                app:iconGravity="textStart"
                app:iconPadding="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:orientation="vertical">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAddWordMenu"
                    style="@style/App.Button.Outlined"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:layout_marginBottom="10dp"
                    android:text="Kelime Ekle"
                    android:textSize="16sp"
                    app:icon="@android:drawable/ic_input_add"
                    app:iconGravity="textStart"
                    app:iconTint="@color/primary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnWordsListMenu"
                    style="@style/App.Button.Outlined"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:layout_marginBottom="10dp"
                    android:text="Kelimelerim"
                    android:textSize="16sp"
                    app:icon="@android:drawable/ic_menu_sort_by_size"
                    app:iconGravity="textStart"
                    app:iconTint="@color/primary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAnalysisMenu"
                    style="@style/App.Button.Outlined"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:layout_marginBottom="10dp"
                    android:text="Analiz Raporu"
                    android:textSize="16sp"
                    app:icon="@android:drawable/ic_menu_report_image"
                    app:iconGravity="textStart"
                    app:iconTint="@color/accent" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnWordleMenu"
                    style="@style/App.Button.Outlined"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:layout_marginBottom="10dp"
                    android:text="Bulmaca (Wordle)"
                    android:textSize="16sp"
                    app:icon="@android:drawable/ic_menu_help"
                    app:iconGravity="textStart"
                    app:iconTint="@color/primary" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnAiMenu"
                    style="@style/App.Button.Outlined"
                    android:layout_width="match_parent"
                    android:layout_height="58dp"
                    android:layout_marginBottom="10dp"
                    android:text="Kelime Zinciri"
                    android:textSize="16sp"
                    app:icon="@android:drawable/ic_menu_edit"
                    app:iconGravity="textStart"
                    app:iconTint="@color/accent" />
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <com.example.kelimeezberleme.BottomNavBarView
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

</LinearLayout>
