<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:orientation="vertical"
    android:paddingHorizontal="@dimen/screen_padding"
    android:paddingTop="@dimen/screen_padding_top">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingBottom="18dp">

        <ImageButton
            android:id="@+id/btnBack"
            style="@style/App.IconButton"
            android:src="@drawable/ic_arrow_back_24"
            app:tint="@color/text_secondary" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                style="@style/App.TitleText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Kelimelerim" />

            <TextView
                style="@style/App.SubtitleText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:text="Kaydettiğin kelimeleri ve örnekleri incele" />
        </LinearLayout>
    </LinearLayout>

    <Spinner
        android:id="@+id/spSort"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/soft_chip_bg"
        android:padding="8dp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvWords"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_weight="1"
        android:clipToPadding="false"
        android:paddingBottom="12dp" />

    <com.example.kelimeezberleme.BottomNavBarView
        android:layout_width="match_parent"
        android:layout_height="wrap_content" />

</LinearLayout>
